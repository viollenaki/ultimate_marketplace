# Application settings
PROJECT_NAME=FastAPI App
SECRET_KEY=change-me-in-production

# API settings
API_V1_STR=/api/v1

# CORS settings
CORS_ORIGINS=http://localhost:8000,http://localhost:3000

# Database settings
# Docker Compose (service name db): mysql+aiomysql://root:PASSWORD@db:3306/ultimate_marketplace
# Local API + MySQL on host: mysql+aiomysql://root:PASSWORD@127.0.0.1:3306/ultimate_marketplace
DATABASE_URL=mysql+aiomysql://root:PASSWORD@db:3306/ultimate_marketplace

# Celery settings
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Elasticsearch (Compose: service name elasticsearch; local API on host: http://127.0.0.1:9200)
ELASTICSEARCH_URL=http://elasticsearch:9200
